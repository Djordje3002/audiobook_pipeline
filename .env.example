# Application
APP_ENV=development
APP_SECRET_KEY=replace-with-a-long-random-value
APP_BASE_URL=http://127.0.0.1:8080
VITE_SUPPORT_EMAIL=hello@yourdomain.com
FREE_CREDITS=15
DATABASE_URL=sqlite:///audiobook_saas.db
ALLOW_BASIC_AUTH=true
APP_USERNAME=admin
APP_PASSWORD=replace-me

# Processing providers
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.6-terra
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSLATION_REASONING_EFFORT=low
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Durable jobs (required in production)
REDIS_URL=
JOB_EXECUTION_MODE=thread
RATELIMIT_STORAGE_URI=

# Object storage (local in development, S3/R2 in production)
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=instance/storage
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Lemon Squeezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_CREATOR_VARIANT_ID=
LEMONSQUEEZY_STUDIO_VARIANT_ID=
